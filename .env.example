# ---------------------------------------------------------------------------
# Helmport configuration. Copy to `.env` and adjust as needed.
# `.env` is git-ignored and never committed.
# ---------------------------------------------------------------------------

# Host port to publish the dashboard on (bound to 127.0.0.1 by compose).
HELMPORT_PORT=8087

# --- Docker connection ------------------------------------------------------
# In production (compose) the app talks to the socket-proxy over TCP:
#   HELMPORT_DOCKER_HOST=socket-proxy
#   HELMPORT_DOCKER_PORT=2375
#
# For local development (bun run dev on the host) leave these unset and the
# app falls back to the local Docker unix socket:
#   HELMPORT_DOCKER_SOCKET=/var/run/docker.sock
